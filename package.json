{
  "name": "document-query-api",
  "version": "1.0.1",
  "description": "API for Colombian document and usury rate queries",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon -r dotenv/config ./src/server.js",
    "build": "babel src --out-dir build",
    "start": "node -r dotenv/config ./src/server.js",
    "test": "jest",
    "test:live": "node scripts/live-smoke.js",
    "createdb": "npx sequelize-cli db:create",
    "migratedb": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "\\\\node_modules\\\\",
      "\\\\build\\\\"
    ]
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.11.5",
    "@babel/core": "^7.11.5",
    "@babel/node": "^7.10.5",
    "@babel/preset-env": "^7.11.5",
    "jest": "^26.4.2",
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.4.1",
    "supertest": "^4.0.2"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^8.6.0",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "helmet": "^4.1.0",
    "moment": "^2.29.1",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.5",
    "puppeteer": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sequelize": "^6.37.8"
  }
}
